import nltk
from nltk.stem import PorterStemmer

# Create stemmer object
stemmer = PorterStemmer()

# List of words
words = ["running", "runs", "runner", "easily", "studies", "studying"]

print("Morphological Analysis using Stemming:")
for word in words:
    stem = stemmer.stem(word)
    print(f"{word} --> {stem}")

OUTPUT

Morphological Analysis using Stemming:
running --> run
runs --> run
runner --> runner
easily --> easili
studies --> studi
studying --> studi
